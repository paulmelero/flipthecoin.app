{
  "private": true,
  "name": "flipthecoinapp-monorepo",
  "description": "The Flip The Coin app monorepo",
  "version": "0.0.0",
  "scripts": {
    "build": "pnpm --filter @flipthecoin/app build",
    "dev": "pnpm --filter @flipthecoin/app dev",
    "og:blog": "node scripts/generate-blog-og-images.mjs",
    "og:series": "node scripts/generate-blog-og-images.mjs --series",
    "og:glossary": "node scripts/generate-blog-og-images.mjs --glossary",
    "og": "pnpm og:blog && pnpm og:series && pnpm og:glossary",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  },
  "devDependencies": {
    "@fontsource/archivo": "^5.0.0",
    "@fontsource/fira-sans": "^5.0.0",
    "@resvg/resvg-js": "^2.6.2",
    "husky": "^9.1.7",
    "katex": "^0.16.10",
    "lint-staged": "^15.4.3",
    "png-to-ico": "^3.0.1",
    "prettier": "3.5.3",
    "satori": "^0.26.0",
    "sharp": "^0.34.5"
  },
  "packageManager": "pnpm@11.6.0"
}
